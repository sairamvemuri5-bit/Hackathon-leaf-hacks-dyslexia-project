# --- Resilient Gemini caller: pings the API up to 3 times with backoff ---
import time as _time

def gemini_post(client, url, payload, attempts=3):
    """POST to Gemini, retrying transient failures (timeouts, 429, 5xx).
    Does NOT retry 400/401/403/404 — those won't fix themselves."""
    last = None
    for i in range(attempts):
        try:
            r = client.post(url, json=payload, headers={"Content-Type": "application/json"})
            if r.status_code == 200 or r.status_code in (400, 401, 403, 404):
                return r
            print(f"Gemini attempt {i + 1}/{attempts}: HTTP {r.status_code} — retrying...")
            last = r
        except Exception as e:
            print(f"Gemini attempt {i + 1}/{attempts} error: {e} — retrying...")
            last = e
        if i < attempts - 1:
            _time.sleep(1.5 * (i + 1))
    if isinstance(last, Exception):
        raise last
    return last

