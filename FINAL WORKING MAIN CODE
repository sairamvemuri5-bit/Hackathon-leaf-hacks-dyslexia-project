# Image generation URL helper (overhauled to produce formal 2D textbook schematics)
def make_pollinations_url(prompt: str) -> str:
    clean_p = re.sub(r'[^\w\s\-,.]', '', prompt)
    clean_p = " ".join(clean_p.split()[:20]) # Limit to 20 words
    style_suffix = "professional 2D educational textbook diagram, clean vector style, flat colors, clear labels, no text in image, no letters, no words, no logos"
    full_prompt = f"{clean_p} {style_suffix}".strip()
    encoded_prompt = urllib.parse.quote(full_prompt)
    return f"https://image.pollinations.ai/prompt/{encoded_prompt}?width=600&height=400&nologo=true&private=true"

# Gemini native image generation (much higher quality than Pollinations).
# Falls back to a Pollinations URL if the model/quota is unavailable.
CARTOON_SUFFIX = "professional 2D educational textbook diagram, clean vector style, flat colors, clear labels, no text in image, no letters, no words, no logos"

def generate_gemini_image(prompt: str, api_key: str) -> Optional[str]:
    try:
        url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key={api_key}"
        payload = {
            "contents": [{
                "parts": [{"text": prompt + CARTOON_SUFFIX}]
            }],
            "generationConfig": {
                "responseModalities": ["IMAGE"]
            }
        }
        with httpx.Client(timeout=60.0) as client:
            response = gemini_post(client, url, payload)
            if response.status_code != 200:
                print(f"Gemini image gen returned {response.status_code}; falling back to Pollinations.")
                return None
            result = response.json()
            for part in result["candidates"][0]["content"]["parts"]:
                inline = part.get("inlineData") or part.get("inline_data")
                if inline and inline.get("data"):
                    mime = inline.get("mimeType") or inline.get("mime_type") or "image/png"
                    return f"data:{mime};base64,{inline['data']}"
    except Exception as e:
        print(f"Gemini image gen failed: {e}; falling back to Pollinations.")
    return None

